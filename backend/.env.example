# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/salary_automation"

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""

# ── Redis (BullMQ job queue) ───────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Razorpay (get from dashboard.razorpay.com → Settings → API Keys) ──
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# RazorpayX account number (for production payouts — not needed for test mode)
RAZORPAY_ACCOUNT_NUMBER=your_razorpayx_account_number
# Webhook secret (Settings → Webhooks → Secret)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Email (SMTP) ───────────────────────────────────────────
# For Gmail: enable 2FA → generate App Password at myaccount.google.com/security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM="SalaryPay <noreply@yourcompany.com>"

# ── App ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
PORT=3000
NODE_ENV=development
