generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  HR_MANAGER
  FINANCE_TEAM
  EMPLOYEE
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  RETRYING
}

enum PaymentMethod {
  NEFT
  IMPS
  UPI
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  phone       String?
  address     String?
  gstin       String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  departments Department[]
  salaryRuns  SalaryRun[]
}

model User {
  id             String   @id @default(uuid())
  organizationId String
  email          String   @unique
  passwordHash   String
  role           Role     @default(EMPLOYEE)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  employee       Employee?
  auditLogs      AuditLog[]
}

model Department {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])
  employees      Employee[]
}

model Employee {
  id              String   @id @default(uuid())
  userId          String   @unique
  organizationId  String
  departmentId    String?
  employeeCode    String
  firstName       String
  lastName        String
  phone           String?
  dateOfJoining   DateTime
  designation     String?
  bankAccountNo   String
  bankIfsc        String
  bankName        String
  upiId           String?
  panNumber       String?
  autoPayLimit    Decimal  @default(0) @db.Decimal(12,2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User         @relation(fields: [userId], references: [id])
  department      Department?  @relation(fields: [departmentId], references: [id])
  salaryStructure SalaryStructure?
  payslips        Payslip[]
  salaryPayments  SalaryPayment[]
}

model SalaryStructure {
  id            String   @id @default(uuid())
  employeeId    String   @unique
  basicSalary   Decimal  @db.Decimal(12,2)
  hra           Decimal  @default(0) @db.Decimal(12,2)
  da            Decimal  @default(0) @db.Decimal(12,2)
  ta            Decimal  @default(0) @db.Decimal(12,2)
  medicalAllow  Decimal  @default(0) @db.Decimal(12,2)
  otherAllow    Decimal  @default(0) @db.Decimal(12,2)
  pfDeduction   Decimal  @default(0) @db.Decimal(12,2)
  esiDeduction  Decimal  @default(0) @db.Decimal(12,2)
  tdsDeduction  Decimal  @default(0) @db.Decimal(12,2)
  otherDeduct   Decimal  @default(0) @db.Decimal(12,2)
  effectiveFrom DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee      Employee @relation(fields: [employeeId], references: [id])
}

model SalaryRun {
  id             String   @id @default(uuid())
  organizationId String
  month          Int
  year           Int
  status         String   @default("DRAFT")
  totalAmount    Decimal  @default(0) @db.Decimal(14,2)
  approvedById   String?
  approvedAt     DateTime?
  executedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  payments       SalaryPayment[]
  payslips       Payslip[]
}

model SalaryPayment {
  id              String        @id @default(uuid())
  salaryRunId     String
  employeeId      String
  grossSalary     Decimal       @db.Decimal(12,2)
  totalDeductions Decimal       @db.Decimal(12,2)
  netSalary       Decimal       @db.Decimal(12,2)
  paymentMethod   PaymentMethod @default(NEFT)
  status          PaymentStatus @default(PENDING)
  razorpayPayoutId String?
  failureReason   String?
  retryCount      Int           @default(0)
  processedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  salaryRun       SalaryRun @relation(fields: [salaryRunId], references: [id])
  employee        Employee  @relation(fields: [employeeId], references: [id])
}

model Payslip {
  id          String   @id @default(uuid())
  employeeId  String
  salaryRunId String
  month       Int
  year        Int
  pdfUrl      String?
  generatedAt DateTime @default(now())

  employee    Employee  @relation(fields: [employeeId], references: [id])
  salaryRun   SalaryRun @relation(fields: [salaryRunId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entity     String
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user       User @relation(fields: [userId], references: [id])
}
